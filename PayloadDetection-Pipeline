class ThreatIntelOrchestrator:
    def __init__(self):
        self.identity = Identity(name="Corporate-Hybrid-WAF-Cluster", identity_class="organization")
        self.mitre_matrix = {
            "SQLi": {"id": "T1190", "name": "Exploit Public-Facing Application: SQL Injection", "desc": "SQL structure modification attempt."},
            "XSS": {"id": "T1190.002", "name": "Exploit Public-Facing Application: DOM-Based XSS", "desc": "Client-side browser script execution exploit."},
            "SSRF": {"id": "T1190", "name": "Exploit Public-Facing Application: Server-Side Request Forgery", "desc": "Inbound payload targeted local host interfaces."}
        }

    def serialize_threat_report(self, payload_string, threat_type, confidence_score):
        if threat_type not in self.mitre_matrix: return None
        m_data = self.mitre_matrix[threat_type]
        safe_str = payload_string.replace("'", "\\'")
        
        indicator = Indicator(
            name=f"WAF-Detected-{threat_type}-Signature",
            description=f"Automated vector pattern matched threat classification with {confidence_score:.2f}% certainty.",
            pattern=f"[network-traffic:extension.'http-request-ext'.body MATCHES '{safe_str}']", pattern_type="stix"
        )
        attack_pattern = AttackPattern(
            name=m_data["name"], description=m_data["desc"],
            external_references=[{"source_name": "mitre-attack", "external_id": m_data["id"], "url": f"https://attack.mitre.org/techniques/{m_data['id'].replace('.', '/')}/"}]
        )
        relationship = Relationship(relationship_type="indicates", source_ref=indicator.id, target_ref=attack_pattern.id)
        bundle = Bundle(objects=[self.identity, indicator, attack_pattern, relationship])
        
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        filename = f"stix_threat_report_{threat_type}_{timestamp}.json"
        with open(filename, "w") as f:
            f.write(bundle.serialize(pretty=True))
        return filename

