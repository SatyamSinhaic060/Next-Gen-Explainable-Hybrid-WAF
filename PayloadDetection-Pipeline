        }).to_csv(CORRECTED_DATA_PATH, index=False)

    df_corr = pd.read_csv(CORRECTED_DATA_PATH)
    model = tf.keras.models.load_model(MODEL_PATH)
    with open(TOKENIZER_PATH, 'rb') as f: tokenizer = pickle.load(f)
