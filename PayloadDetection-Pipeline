# ENGINE PHASE 1: STRUCTURAL VECTOR MATHEMATICS ENGINE
# =====================================================================
class StructuralWAFParser:
    def __init__(self):
        self.ipv4 = re.compile(r'(?:\d{1,3}\.){3}\d{1,3}')
        self.ipv6 = re.compile(r'(([0-9a-fA-F]{1,4}:){7,7}[0-9a-fA-F]{1,4}|([0-9a-fA-F]{1,4}:){1,7}:|([0-9a-fA-F]{1,4}:){1,6}:[0-9a-fA-F]{1,4})')
        self.hex_ip = re.compile(r'0x[0-9a-fA-F]{2,8}')
        self.hex_pct = re.compile(r'%[0-9a-fA-F]{2}')
        self.html_tag = re.compile(r'</?[a-zA-Z][^>]*>')
        self.sql_tautology = re.compile(r'(\w+)\s*=\s*\1|(\d+)\s*=\s*\2')
        self.union_select = re.compile(r'union\s+(?:all\s+)?select')

    def _shannon_entropy(self, s):
        if not s: return 0.0
        return float(-sum((count / len(s)) * math.log(count / len(s), 2) for count in [s.count(c) for c in set(s)]))

    def extract_features(self, text_array):
        matrix = []
        for text in text_array:
            s = str(text)
            low = s.lower()
            L = len(s) if len(s) > 0 else 1

            f_stat = [float(len(s)), self._shannon_entropy(s), sum(1 for c in s if c.isupper()) / L, sum(1 for c in s if c.isdigit()) / L]
            chars_to_track = ["'", '"', '`', ';', ',', '(', ')', '[', ']', '{', '}', '\\', '/', '?']
            f_punct = [s.count(c) / L for c in chars_to_track]
            special_tokens = ['--', '#', '/*', '*/', '<', '>', '=', '!', '|', '&']
            f_special = [s.count(tok) / L for tok in special_tokens]

            f_evasion = [
                float(low.count('http://') + low.count('https://')) / L,
                1.0 if self.ipv4.search(s) else 0.0,
                1.0 if self.ipv6.search(s) else 0.0,
                1.0 if self.hex_ip.search(low) else 0.0,
                float(len(self.hex_pct.findall(s))) / L,
                1.0 if self.html_tag.search(s) else 0.0,
                1.0 if self.sql_tautology.search(low) else 0.0,
                1.0 if self.union_select.search(low) else 0.0,
                float(s.count('  ')) / L,
                1.0 if ('\n' in s or '\r' in s) else 0.0,
                float(s.count('%00') + s.count('\\0')) / L,
                1.0 if 'base64' in low else 0.0,
                1.0 if 'char(' in low else 0.0,
                1.0 if 'string.fromcharcode' in low else 0.0
            ]
            matrix.append(f_stat + f_punct + f_special + f_evasion)
        return np.array(matrix, dtype=np.float32)

