    def _canonicalize_payload(self, payload_string):
        """ Recursively unpacks obfuscated payload masking to restore clear-text syntax profiles """
        current = str(payload_string)
        max_depth = 3
        
        for _ in range(max_depth):
            previous = current
            current = urllib.parse.unquote(current)
            current = html.unescape(current)
            current = re.sub(r'(?:\\x|0x)([0-9a-fA-F]{2})', lambda m: chr(int(m.group(1), 16)), current)
            
            # Identify and translate standalone Base64 strings matching typical attack block formats
            b64_matches = re.findall(r'\b[A-Za-z0-9+/]{4,}={0,2}\b', current)
            for match in b64_matches:
                try:
                    decoded_b64 = base64.b64decode(match).decode('utf-8', errors='ignore')
                    if any(tag in decoded_b64.lower() for tag in ['<', '>', 'script', 'select', 'union']):
                        current = current.replace(match, decoded_b64)
                except Exception:
                    continue
                    
            if current == previous:
                break
        return current

    def _is_dangerous_ssrf_host(self, url_string):
        """ Decoupled socket address evaluation wrapper targeting integer, hex, octal, and loopback ranges """
        try:
            # Append protocol structure if dealing with raw IP sequences to ensure successful extraction
            if not url_string.lower().startswith(('http://', 'https://')):
                parsed_url = urllib.parse.urlparse('http://' + url_string)
            else:
                parsed_url = urllib.parse.urlparse(url_string)
                
            hostname = parsed_url.hostname
            if not hostname:
                # Strip out query markers if parsing complex inline targets directly
                hostname = url_string.split('/')[0].split('?')[0].split(':')[0]
            
            # Resolve structural string values against system DNS architecture to catch translation tricks
            resolved_ip_str = socket.gethostbyname(hostname)
            ip_obj = ipaddress.ip_address(resolved_ip_str)
            
            if ip_obj.is_private or ip_obj.is_loopback or ip_obj.is_link_local:
                return True
            return False
        except Exception:
            return False

    def inspect_traffic(self, payload_string):
        if not hasattr(self, 'model'): return "UNCONFIGURED"
        
        # Ingest raw format sequences directly into the deep learning input nodes
        feat = self.parser.extract_features([payload_string])
        seq = pad_sequences(self.tokenizer.texts_to_sequences([payload_string]), maxlen=MAX_CHARS, padding='post')
        
        pred_probs = self.model.predict([seq, feat], verbose=0)[0]
        predicted_idx = np.argmax(pred_probs)
        ai_pred = TARGET_NAMES[predicted_idx]
        ai_conf = pred_probs[predicted_idx] * 100
        
        final_verdict = ai_pred
        override_triggered = False

        # Generate canonical strings to expose hidden markers to circuit breakers
        normalized = self._canonicalize_payload(payload_string)

        # --- DUAL-SIDED VALIDATION RING CORE ---
        
        # Branch 1: Mitigate False Positives (AI alerts Malicious, but execution tokens are missing)
        if ai_pred == 'SQLi' and not REAL_SQLI_SYNTAX.search(normalized):
            final_verdict = 'Benign'; override_triggered = True
        elif ai_pred == 'SSRF' and not (REAL_SSRF_SYNTAX.search(normalized) or self._is_dangerous_ssrf_host(normalized)):
            final_verdict = 'Benign'; override_triggered = True
        elif ai_pred == 'XSS' and not REAL_XSS_SYNTAX.search(normalized):
            final_verdict = 'Benign'; override_triggered = True

        # Branch 2: Mitigate False Negatives (AI claims Benign, but explicit markers match)
        elif ai_pred == 'Benign':
            has_sqli_keyword = any(
              re.search(rf"\b{word}\b", normalized.lower()) 
              for word in ['select', 'union', 'where', 'or', 'and']
            ) or any(x in normalized.lower() for x in ['0x', '/*', '*/'])

            if REAL_SQLI_SYNTAX.search(normalized) and has_sqli_keyword:
                final_verdict = 'SQLi'; override_triggered = True; predicted_idx = 2; ai_conf = 100.0
            elif self._is_dangerous_ssrf_host(normalized) or (REAL_SSRF_SYNTAX.search(normalized) and any(x in normalized.lower() for x in ['http', 'metadata', 'aws', 'internal', 'compute', '@', 'v1'])):
                final_verdict = 'SSRF'; override_triggered = True; predicted_idx = 3; ai_conf = 100.0
            elif REAL_XSS_SYNTAX.search(normalized) and any(x in normalized.lower() for x in ['<', '>', 'script', 'onload', 'onerror', 'charcode']):
                final_verdict = 'XSS'; override_triggered = True; predicted_idx = 1; ai_conf = 100.0

        print(f"\nPayload Evaluated: \"{payload_string}\"")
        if override_triggered:
            print(f" ├─ ML Prediction Model Alert: {ai_pred} ({pred_probs[np.argmax(pred_probs)]*100:.2f}%)")
            print(f" ├─ [CIRCUIT BREAKER OVERRIDE]: Conflicting structural parameters. Re-routing payload...")
            
            with open(AUDIT_LOG_PATH, "a") as f:
                f.write(f"{datetime.now().isoformat()}|||{predicted_idx}|||{ai_conf:.2f}|||{payload_string}\n")

        print(f" └─ RUNTIME ROUTING DECISION: ──> **{final_verdict}** (Final Status Confirmation)")
        
        if final_verdict != 'Benign':
            print(f"    [!] Threat Confirmed. Auto-generating cryptographic STIX report...")
            report_file = self.orchestrator.serialize_threat_report(payload_string, final_verdict, ai_conf)
            print(f"    [+] Forensic asset written to workspace disk as: '{report_file}'")

        # =====================================================================
        # DECOUPLED DYNAMIC SHAP ENGINE
        # =====================================================================
        if self.enable_shap:
            print("\n    🔬 [INLINE SHAP DEEP ANALYSIS FOR CURRENT PAYLOAD]:")
            
            def shap_predict_dynamic(feat_mat):
                batch_size = feat_mat.shape[0]
                repeated_seqs = np.repeat(seq, batch_size, axis=0)
                return self.model.predict([repeated_seqs, feat_mat], verbose=0)
            
            explainer = shap.KernelExplainer(shap_predict_dynamic, np.zeros((1, 42), dtype=np.float32))
            shap_val = explainer.shap_values(feat, silent=True)
            
            if isinstance(shap_val, list):
                class_shap = shap_val[predicted_idx][0]
            else:
                if len(shap_val.shape) == 3:
                    class_shap = shap_val[0, :, predicted_idx]
                else:
                    class_shap = shap_val[0]

            top_i = np.argsort(np.abs(class_shap))[::-1][:3]
            for rank, i in enumerate(top_i):
                print(f"      └─ Top {rank+1}: {FEATURE_NAMES[i]} (Impact Magnitude: {class_shap[i]:.4f})")

