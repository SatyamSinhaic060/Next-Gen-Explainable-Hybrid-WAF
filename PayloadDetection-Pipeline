    gateway = ProductionWAFGateway(use_finetuned=False, enable_shap=True)
    
    print("\n🚀 INTERACTIVE HYBRID WAF GATEWAY ONLINE")
    print("Type your custom request string payload below to test the pipeline (or type 'exit' to quit).")
    print("=" * 80)
    
    while True:
