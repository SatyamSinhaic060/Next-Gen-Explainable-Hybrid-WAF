        r.write(f"# WAF Fine-Tuning Performance Audit Report\n**Timestamp:** {datetime.now().isoformat()}\n\n"
                f"* Final Step Training Loss: {history.history['loss'][-1]:.6f}\n"
                f"* Final Step Training Accuracy: {history.history['accuracy'][-1]*100:.2f}%\n"
                f"Ingested {len(df_corr)} analyst-corrected edge entries securely.\n")
    print(f"[+] Operational audit saved to workspace: '{report_filename}'")

