# SYSTEM COMPONENT A: BALANCED BASELINE LAYER TRAINING FROM ZERO
# =====================================================================
def run_clean_baseline_training():
    print("\n============================================================\n"
          "         PHASE A: EXECUTING COMPLETE BASELINE MODEL TRAINING\n"
          "============================================================")
    if not os.path.exists(RAW_DATASET_PATH):
        print(f"[!] Target matrix file '{RAW_DATASET_PATH}' missing. Cannot execute baseline training.")
        return

    df = pd.read_csv(RAW_DATASET_PATH).drop_duplicates(subset=['text']).copy()
    min_size = df['label'].value_counts().min()
    balanced = pd.concat([df[df['label'] == l].sample(n=min_size, random_state=42) for l in sorted(df['label'].unique())])
    df_bal = balanced.sample(frac=1, random_state=42).reset_index(drop=True)
    
    parser = StructuralWAFParser()
    X_feats = parser.extract_features(df_bal['text'].values)
    
    tokenizer = Tokenizer(char_level=True, lower=True, oov_token="<OOV>", filters="")
    tokenizer.fit_on_texts(df_bal['text'].values)
    with open(TOKENIZER_PATH, 'wb') as f: pickle.dump(tokenizer, f)
    X_seqs = pad_sequences(tokenizer.texts_to_sequences(df_bal['text'].values), maxlen=MAX_CHARS, padding='post')
    
    X_train_seq, X_test_seq, X_train_feat, X_test_feat, y_train, y_test = train_test_split(
        X_seqs, X_feats, df_bal['label'].values, test_size=0.2, stratify=df_bal['label'].values, random_state=42
    )

    # --- BALANCED ARCHITECTURE GRAPH RE-WEIGHTING ---
    seq_in = Input(shape=(MAX_CHARS,), name="Sequence_Text_Input")
    embed = Embedding(input_dim=len(tokenizer.word_index)+1, output_dim=64, name="Char_Embedding")(seq_in)
    
    # Expanded sequence tracking matrix width to boost context awareness (64 -> 128 units)
    lstm = Bidirectional(LSTM(128, return_sequences=False), name="Bi_LSTM_Processor")(embed)
    lstm = Dropout(0.4)(lstm)

    # Scaled down dense node processing limits to reduce tabular layout dominance (64 -> 32 nodes)
    feat_in = Input(shape=(42,), name="Engineered_Structural_Features_Input")
    dense_f = Dense(32, activation='relu', name="Dense_Feature_L1")(feat_in)
    dense_f = BatchNormalization()(dense_f)
    dense_f = Dropout(0.3)(dense_f)
    dense_f = Dense(16, activation='relu', name="Dense_Feature_L2")(dense_f)

    merged = Concatenate(name="Feature_Sequence_Fusion")([lstm, dense_f])
    core = Dense(64, activation='relu', name="Unified_Hidden_Layer")(merged)
    core = Dropout(0.3)(core)
    out = Dense(4, activation='softmax', name="WAF_Classification_Output")(core)

    model = Model(inputs=[seq_in, feat_in], outputs=out)
    model.compile(optimizer='adam', loss='sparse_categorical_crossentropy', metrics=['accuracy'])
    
    model.fit([X_train_seq, X_train_feat], y_train, validation_data=([X_test_seq, X_test_feat], y_test), 
              epochs=15, batch_size=64, callbacks=[tf.keras.callbacks.EarlyStopping(monitor='val_loss', patience=3, restore_best_weights=True)])
    model.save(MODEL_PATH)
    print(f"[+] Core structural network saved to: '{MODEL_PATH}'")

