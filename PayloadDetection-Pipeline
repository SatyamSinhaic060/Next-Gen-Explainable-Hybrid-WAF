    X_feats = parser.extract_features(df_corr['text'].values)
    X_seqs = pad_sequences(tokenizer.texts_to_sequences(df_corr['text'].values), maxlen=MAX_CHARS, padding='post')

    print("[*] Freezing Early Sequence and Feature Graph layers...")
    for layer in model.layers:
        if any(name in layer.name for name in ["Char_Embedding", "Bi_LSTM", "Dense_Feature_L1"]):
            layer.trainable = False
        else:
            layer.trainable = True

    model.compile(optimizer=tf.keras.optimizers.Adam(learning_rate=0.0001), loss='sparse_categorical_crossentropy', metrics=['accuracy'])
    history = model.fit([X_seqs, X_feats], df_corr['label'].values, epochs=5, batch_size=2, verbose=1)
